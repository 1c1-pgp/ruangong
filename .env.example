# 复制为 .env 或在系统环境变量中设置（不要将含真实密码的 .env 提交到 Git）

MONGODB_URI=mongodb://localhost:27017/chatdb
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=false

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
FASTDFS_NGINX_HOST=127.0.0.1

# 前后端不同域名时必填（逗号分隔，勿与 credentials 同时使用 *）
# CORS_ALLOWED_ORIGIN_PATTERNS=https://你的前端域名,https://www.你的前端域名
